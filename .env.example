# Supabase PostgreSQL Connection
DATABASE_URL=postgresql://user:password@your-supabase-host.supabase.co:5432/postgres

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_here

# Server Configuration
PORT=5000
NODE_ENV=production

# Vercel API URL (for frontend)
REACT_APP_API_URL=https://your-project-name.vercel.app/api
